<Page
    x:Class="MarketPlace4Win10Mobile.MainPage"
    xmlns="http://microsoft.com"
    xmlns:x="http://microsoft.com"
    xmlns:local="using:MarketPlace4Win10Mobile"
    xmlns:d="http://microsoft.com"
    xmlns:mc="http://openxmlformats.org"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <!-- FlipViewによる画面切り替え -->
        <FlipView x:Name="SetupFlipView">
            
            <!-- ページ1：ようこそ -->
            <FlipViewItem>
                <Grid Margin="24,32,24,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0">
                        <!-- システムのアクセントカラーで染まるテキスト -->
                        <TextBlock Text="MARKETPLACE FOR W10M" FontSize="12" FontWeight="Bold" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" CharacterSpacing="100"/>
                        <TextBlock Text="ようこそ" FontSize="48" FontWeight="Light" Margin="0,10,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="12">
                        <TextBlock Text="このアプリはGitHub経由でアプリ更新、インストールできるハブです。" TextWrapping="Wrap" FontSize="18" Opacity="0.8"/>
                        <TextBlock Text="右へスワイプして設定を開始してください。" TextWrapping="Wrap" FontSize="14" Foreground="Gray" Margin="0,24,0,0"/>
                    </StackPanel>
                </Grid>
            </FlipViewItem>

            <!-- ページ2：GitHub PAT設定（任意） -->
            <FlipViewItem>
                <Grid Margin="24,32,24,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="MARKETPLACE FOR W10M" FontSize="12" FontWeight="Bold" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" CharacterSpacing="100"/>
                        <TextBlock Text="github連携" FontSize="48" FontWeight="Light" Margin="0,10,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <TextBlock Text="GitHub APIの回数制限（60回/h）を回避したい場合は、あなたのパーソナルアクセストークン（PAT）を入力してください。" TextWrapping="Wrap" FontSize="16" Margin="0,0,0,24"/>
                        <!-- プレースホルダーとテキストボックス -->
                        <TextBox x:Name="TokenInput" PlaceholderText="ghp_... (未入力でも可)" Header="Personal Access Token"/>
                    </StackPanel>

                    <!-- システムのアクセントカラーでカチッと染まるボタン -->
                    <Button Grid.Row="2" Content="ストアを起動" 
                            HorizontalAlignment="Stretch" 
                            Background="{ThemeResource SystemControlHighlightAccentBrush}" 
                            Foreground="White" 
                            FontSize="18" 
                            Padding="12"
                            Click="StartStore_Click"/>
										<!-- 大江戸コントローラー神曲過ぎる！ -->
                </Grid>
            </FlipViewItem>
            
        </FlipView>
    </Grid>
</Page>
